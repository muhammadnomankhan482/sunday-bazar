# ─── Frontend (frontend/.env.local) ───
NEXT_PUBLIC_BACKEND_URL=http://localhost:5000

# Production: set to your deployed backend URL, e.g.
# NEXT_PUBLIC_BACKEND_URL=https://your-backend.vercel.app

# ─── Backend (backend/.env) ───
PORT=5000
